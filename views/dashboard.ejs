<%- include('_head') %><%- include('_nav') %>
<style>
  .setup { display:flex; flex-wrap:wrap; gap:1rem; align-items:baseline; }
  .setup .lvl { background:#0b1220; border:1px solid #334155; border-radius:6px; padding:.3rem .6rem; }
  .setup .lvl b { display:block; font-size:1.05rem; }
  .side-long { color:var(--good); } .side-short { color:var(--bad); }
</style>
<main>
  <% if (lastRun && lastRun.status !== 'ok') { %>
    <div class="card" style="border-left:4px solid var(--bad)">
      Sync <strong><%= lastRun.status %></strong> — started <%= new Date(lastRun.started_at).toLocaleString('nl-NL') %>.
      Showing last good data. <a href="/admin">Details</a>
    </div>
  <% } %>

  <div class="card">
    <h2>Trade setups <span class="muted" style="font-size:.85rem">
      <%= setups.length %> found · <%= scanned %> strategies scanned</span></h2>
    <p class="muted" style="font-size:.83rem">Where this year's spread is tracking prior years that then made a repeatable move. Probabilistic analysis, not trade advice — always your own call.</p>
    <% if (!setups.length) { %>
      <p class="muted">No setups today<% if (scanned === 0) { %> — import strategies and run a sync from <a href="/admin">Admin</a><% } %>.</p>
    <% } %>
  </div>

  <% for (const r of setups) { const t = r.analog.trade; const v = r.verdict || {}; %>
  <div class="card">
    <div class="setup">
      <h3 style="margin:0"><a href="/strategies/<%= r.id %>"><%= r.save_name %></a></h3>
      <span class="badge <%= t.side === 'long' ? 'flag' : 'fail' %>"><%= t.side === 'long' ? '▲ LONG' : '▼ SHORT' %> the spread</span>
      <span class="muted">score <%= Math.round(r.setup_score || 0) %> · prob <%= v.probability != null ? v.probability + '%' : '—' %>
        · <%= t.agreeCount %> analog years agree · R:R ≈ <%= t.rr %></span>
    </div>
    <div class="setup" style="margin-top:.7rem">
      <span class="lvl">entry <b><%= t.entry %></b></span>
      <span class="lvl">target <b class="<%= t.side === 'long' ? 'side-long' : 'side-short' %>"><%= t.target %></b></span>
      <span class="lvl">stop <b class="<%= t.side === 'long' ? 'side-short' : 'side-long' %>"><%= t.stop %></b></span>
      <span class="lvl">ideal exit <b><%= t.exitDate || '—' %></b></span>
    </div>
    <% if (v.headline) { %>
      <p style="margin:.7rem 0 0"><strong><%= v.headline %></strong> — <%= v.rationale %></p>
      <p class="muted" style="font-size:.82rem;margin:.3rem 0 0">
        Risk: <%= v.risk %><% if (v.source === 'fallback') { %> · <span class="badge off">computed (no AI key)</span><% } %></p>
    <% } %>
  </div>
  <% } %>
</main></body></html>
