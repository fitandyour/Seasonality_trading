<%- include('_head') %><%- include('_nav') %>
<main>
  <% if (msg) { %><div class="card" style="border-left:4px solid var(--good)"><%= msg %></div><% } %>
  <% if (err) { %><div class="card" style="border-left:4px solid var(--bad)"><%= err %></div><% } %>

  <div class="card">
    <h2>Add fills</h2>
    <% if (visionAvailable) { %>
    <form method="post" action="/trades/upload" enctype="multipart/form-data" class="stack" style="max-width:520px">
      <label class="muted">TT order-book screenshot (filled orders are read automatically)</label>
      <input type="file" name="screenshot" accept="image/*" required>
      <label class="muted">Fill date (screenshots carry no date)</label>
      <input type="date" name="trade_date" value="<%= today %>" required>
      <button>Upload & parse</button>
    </form>
    <% } else { %>
    <p class="muted">Screenshot parsing needs <code>ANTHROPIC_API_KEY</code> in Railway — until then, add trades manually below.</p>
    <% } %>
    <details style="margin-top:.8rem">
      <summary class="muted">Add a trade manually</summary>
      <form method="post" action="/trades/add" class="stack" style="max-width:520px;margin-top:.6rem">
        <div style="display:flex;gap:.5rem">
          <select name="side"><option value="buy">Buy</option><option value="sell">Sell</option></select>
          <input name="qty" type="number" min="1" value="1" style="width:5rem" required>
          <input name="symbol" placeholder="GF" style="width:5rem" required>
        </div>
        <input name="contract" placeholder="Aug26-Oct26 Calendar" required>
        <div style="display:flex;gap:.5rem">
          <input name="price" type="number" step="any" placeholder="Level (e.g. 7.425 or -0.525)" required>
          <input name="account" placeholder="Account (optional)">
          <input name="trade_date" type="date" value="<%= today %>">
        </div>
        <button>Add trade</button>
      </form>
    </details>
  </div>

  <div class="card">
    <h2>Open positions <span class="muted" style="font-size:.85rem"><%= open.length %></span></h2>
    <p class="muted" style="font-size:.82rem">Each open trade shown individually — this count matches the <strong>OPEN</strong>/partial rows in the fill list below.</p>
    <% if (!open.length) { %><p class="muted">Flat — no open positions.</p><% } else { %>
    <table>
      <tr><th>Since</th><th>Position</th><th>Qty</th><th>Entry level</th><th>Type</th></tr>
      <% for (const p of open) { %>
      <tr>
        <td><%= p.since %></td>
        <td><span class="badge <%= p.side === 'long' ? 'flag' : 'fail' %>"><%= p.side.toUpperCase() %></span> <%= p.key %></td>
        <td><%= p.qty %></td>
        <td><%= p.price %></td>
        <td class="muted"><%= p.type %></td>
      </tr>
      <% } %>
    </table>
    <% } %>
    <p style="margin-top:.6rem"><a href="/trades/report">→ Monthly report</a></p>
  </div>

  <% if (recentClosed.length) { %>
  <div class="card">
    <h2>Recently closed</h2>
    <table>
      <tr><th>Exit</th><th>Trade</th><th>Qty</th><th>Entry→Exit</th><th>Points</th><th>P&L</th><th>Held</th></tr>
      <% for (const t of recentClosed) { %>
      <tr>
        <td><%= t.exitDate %></td>
        <td><%= t.side %> <%= t.key %></td>
        <td><%= t.qty %></td>
        <td><%= t.entryPrice %> → <%= t.exitPrice %></td>
        <td style="color:<%= t.points > 0 ? 'var(--good)' : (t.points < 0 ? 'var(--bad)' : 'inherit') %>"><%= t.points %></td>
        <td style="color:<%= (t.pnl||0) > 0 ? 'var(--good)' : ((t.pnl||0) < 0 ? 'var(--bad)' : 'inherit') %>"><%= t.pnl == null ? '—' : '$' + t.pnl %></td>
        <td class="muted"><%= t.holdDays %>d</td>
      </tr>
      <% } %>
    </table>
  </div>
  <% } %>

  <div class="card">
    <h2>All fills <span class="muted" style="font-size:.85rem">last <%= fills.length %></span></h2>
    <p class="muted" style="font-size:.82rem">
      <span class="badge off">OPEN</span> still on · <span style="text-decoration:line-through;opacity:.6">closed</span> matched into a round trip · <span style="opacity:.75">partial</span> partly matched.
      Edit a row to fix a mis-read contract so a stuck pair nets off.
    </p>
    <% if (!fills.length) { %><p class="muted">No fills recorded yet.</p><% } else { %>
    <% for (const f of fills) { %>
      <form id="e<%= f.id %>" method="post" action="/trades/<%= f.id %>/edit" style="display:none"></form>
      <form id="d<%= f.id %>" method="post" action="/trades/<%= f.id %>/delete" style="display:none" onsubmit="return confirm('Delete this fill?')"></form>
    <% } %>
    <table>
      <tr><th>Date</th><th>Side</th><th>Qty</th><th>Symbol</th><th>Contract</th><th>Level</th><th>State</th><th></th></tr>
      <% for (const f of fills) { const st = status[f.id] || 'open';
         const rowStyle = st === 'closed' ? 'text-decoration:line-through;opacity:.55' : (st === 'partial' ? 'opacity:.8' : ''); %>
      <tr style="<%= rowStyle %>">
        <td><input form="e<%= f.id %>" type="date" name="trade_date" value="<%= f.trade_date %>" style="padding:.15rem .3rem;font-size:.82rem;width:8.5rem"></td>
        <td><select form="e<%= f.id %>" name="side" style="padding:.15rem;font-size:.82rem">
          <option value="buy" <%= f.side === 'buy' ? 'selected' : '' %>>buy</option>
          <option value="sell" <%= f.side === 'sell' ? 'selected' : '' %>>sell</option>
        </select></td>
        <td><input form="e<%= f.id %>" name="qty" type="number" min="1" value="<%= f.qty %>" style="width:3.2rem;padding:.15rem;font-size:.82rem"></td>
        <td><input form="e<%= f.id %>" name="symbol" value="<%= f.symbol %>" style="width:3.5rem;padding:.15rem;font-size:.82rem"></td>
        <td><input form="e<%= f.id %>" name="contract" value="<%= f.contract %>" style="width:14rem;padding:.15rem;font-size:.82rem"></td>
        <td><input form="e<%= f.id %>" name="price" type="number" step="any" value="<%= f.price %>" style="width:5rem;padding:.15rem;font-size:.82rem"></td>
        <td>
          <% if (st === 'closed') { %><span class="muted">closed</span>
          <% } else if (st === 'partial') { %><span class="badge" style="background:var(--warn);color:#3a2c02">partial</span>
          <% } else { %><span class="badge off">OPEN</span><% } %>
        </td>
        <td style="white-space:nowrap">
          <button form="e<%= f.id %>" style="padding:.15rem .45rem;font-size:.78rem" title="Save changes">save</button>
          <button form="d<%= f.id %>" style="background:var(--bad);padding:.15rem .45rem;font-size:.78rem" title="Delete fill">✕</button>
        </td>
      </tr>
      <% } %>
    </table>
    <% } %>
  </div>
</main></body></html>
