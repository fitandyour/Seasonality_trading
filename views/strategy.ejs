<%- include('_head') %><%- include('_nav') %>
<style>
  .setup { display:flex; flex-wrap:wrap; gap:1rem; align-items:baseline; }
  .setup .lvl { background:#0b1220; border:1px solid #334155; border-radius:6px; padding:.3rem .6rem; }
  .setup .lvl b { display:block; font-size:1.05rem; }
  .side-long { color:var(--good); } .side-short { color:var(--bad); }
  .line.current{stroke:var(--accent);stroke-width:2.5}.line.prior{stroke:#64748b;stroke-width:1;opacity:.7}
</style>
<main>
  <div class="card">
    <h2><%= strategy.save_name %></h2>
    <p class="muted">Window: <%= strategy.config.window.openMonth %> <%= strategy.config.window.openDate %>
      → <%= strategy.config.window.closeMonth %> <%= strategy.config.window.closeDate %>
      · <%= strategy.active ? 'active' : 'paused' %></p>
  </div>

  <% if (!cycles.length) { %>
  <div class="card"><p class="muted">Not analysed yet — run a sync from <a href="/admin">Admin</a>.</p></div>
  <% } %>

  <% for (const c of cycles) { const v = c.verdict; const a = c.analog; %>
  <div class="card">
    <h3 style="text-transform:capitalize"><%= c.label %> cycle
      <span class="badge off" style="text-transform:none"><%= c.front %></span></h3>

    <% if (v && v.opportunity) { %>
      <div class="setup" style="margin-top:.5rem">
        <span class="badge <%= v.side === 'long' ? 'flag' : 'fail' %>"><%= v.side === 'long' ? '▲ LONG' : '▼ SHORT' %></span>
        <span class="muted">prob <%= v.probability %>% · confidence <%= v.confidence %></span>
      </div>
      <div class="setup" style="margin-top:.7rem">
        <span class="lvl">entry <b><%= v.entry ?? '—' %></b></span>
        <span class="lvl">target <b class="<%= v.side === 'long' ? 'side-long' : 'side-short' %>"><%= v.target ?? '—' %></b></span>
        <span class="lvl">stop <b class="<%= v.side === 'long' ? 'side-short' : 'side-long' %>"><%= v.stop ?? '—' %></b></span>
        <span class="lvl">ideal exit <b><%= v.exitDate || '—' %></b></span>
      </div>
      <p style="margin:.8rem 0 0"><strong><%= v.headline %></strong></p>
      <p><%= v.rationale %></p>
      <p class="muted">Risk: <%= v.risk %>
        <% if (v.source === 'fallback') { %><span class="badge off">computed (no AI key)</span><% } %></p>
    <% } else if (v) { %>
      <p class="muted" style="margin-top:.5rem">No tradeable setup — <%= v.headline %>.
        <% if (v.rationale) { %><%= v.rationale %><% } %>
        <% if (v.source === 'fallback') { %><span class="badge off">computed (no AI key)</span><% } %></p>
    <% } else { %>
      <p class="muted" style="margin-top:.5rem">Too little data in this cycle to analyse yet.</p>
    <% } %>

    <% if (a && a.years && a.years.length) { %>
    <table style="margin-top:.8rem">
      <tr><th>Year</th><th>Similarity</th><th>Next move</th><th>Best</th><th>Worst</th><th>Level then</th><th>vs now</th></tr>
      <% for (const y of a.years) { %>
      <tr>
        <td><%= y.label %></td>
        <td><%= y.similarity == null ? '—' : Number(y.similarity).toFixed(2) %></td>
        <td style="color:<%= y.nextMove > 0 ? 'var(--good)' : (y.nextMove < 0 ? 'var(--bad)' : 'inherit') %>">
            <%= y.nextMove == null ? '—' : Number(y.nextMove).toFixed(2) %></td>
        <td><%= y.maxFavorable == null ? '—' : Number(y.maxFavorable).toFixed(2) %></td>
        <td><%= y.maxAdverse == null ? '—' : Number(y.maxAdverse).toFixed(2) %></td>
        <td><%= y.levelThen == null ? '—' : Number(y.levelThen).toFixed(2) %></td>
        <td><%= y.levelGap == null ? '—' : Number(y.levelGap).toFixed(2) %></td>
      </tr>
      <% } %>
    </table>
    <% if (a.analogCount) { %>
    <p class="muted" style="font-size:.82rem">Agreement <%= a.agreementCount %>/<%= a.analogCount %> ·
       mean next move <%= Number(a.meanNextMove).toFixed(2) %> · opposite-side risk <%= Number(a.oppositeRisk).toFixed(2) %></p>
    <% } %>
    <% } %>

    <% if (c.svg) { %>
    <p class="muted" style="font-size:.82rem;margin-bottom:.2rem">Front year (blue) vs the prior years (grey)</p>
    <%- c.svg %>
    <% } %>
  </div>
  <% } %>

  <% if (strategy.source_url) { %>
  <p><a href="<%= strategy.source_url %>" target="_blank">Open on Scarr ↗</a></p>
  <% } %>
</main></body></html>
