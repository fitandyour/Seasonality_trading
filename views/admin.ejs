<%- include('_head') %><%- include('_nav') %>
<main>
  <div class="card">
    <h2>Admin</h2>
    <form method="post" action="/admin/sync" style="display:inline"><button>Sync now</button></form>
    <form method="post" action="/admin/import-all" style="display:inline;margin-left:1rem"><button>Import all from Scarr</button></form>
    <form method="post" action="/admin/settings" style="display:inline;margin-left:1rem">
      Flag threshold: <input name="threshold" type="number" min="0" max="100" value="<%= threshold %>" style="width:5rem">
      <button>Save</button>
    </form>
  </div>
  <div class="card">
    <h3>Anthropic AI</h3>
    <p class="muted" style="font-size:.85rem">
      Controls the costly part: Claude's setup evaluation during the seasonal sync and the monthly coach.
      Turn off to run those on the computed engine at no API cost.
      <strong>Screenshot reading for trade logging always works</strong> when a key is set — it is not affected by this switch.
      <% if (!hasKey) { %><br><span style="color:var(--warn)">No ANTHROPIC_API_KEY set in Railway — AI is unavailable.</span><% } %>
    </p>
    <form method="post" action="/admin/ai-toggle" style="display:flex;align-items:center;gap:.7rem">
      <label class="switch">
        <input type="checkbox" name="ai_enabled" onchange="this.form.submit()" <%= aiEnabled ? 'checked' : '' %>>
        <span class="slider"></span>
      </label>
      <span><strong><%= aiEnabled ? 'AI ON' : 'AI OFF' %></strong> — <%= aiEnabled ? 'Claude evaluates setups and reads screenshots' : 'computed engine only, no API cost' %></span>
    </form>
  </div>

  <div class="card">
    <h3>Point multipliers ($ per 1.00 point, per symbol)</h3>
    <p class="muted" style="font-size:.83rem">Used to turn spread points into dollars in the trade journal. JSON — edit and save.</p>
    <form method="post" action="/admin/multipliers" class="stack" style="max-width:520px">
      <textarea name="multipliers" rows="4" style="font-family:monospace"><%= JSON.stringify(multipliers) %></textarea>
      <button>Save multipliers</button>
    </form>
  </div>
  <div class="card"><h3>Sync history</h3><table>
    <tr><th>Started</th><th>Status</th><th>Detail</th></tr>
    <% for (const r of runs) { %>
    <tr>
      <td><%= new Date(r.started_at).toLocaleString('nl-NL') %></td>
      <td><span class="badge <%= r.status === 'ok' ? 'flag' : (r.status === 'running' ? 'off' : 'fail') %>"><%= r.status %></span></td>
      <td class="muted" style="font-size:.8rem">
        <% const d = r.detail || []; %>
        <%= d.filter(x => x.ok).length %> ok, <%= d.filter(x => !x.ok).length %> failed
        <% for (const f of d.filter(x => !x.ok).slice(0, 5)) { %><br><%= f.saveName %>: <%= f.error %><% } %>
      </td>
    </tr>
    <% } %>
  </table></div>
</main></body></html>
