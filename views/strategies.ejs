<%- include('_head') %><%- include('_nav') %>
<main>
  <div class="card">
    <h2>Strategies <a href="/strategies/import" style="font-size:.9rem">+ import</a></h2>
    <table>
      <tr><th>Name</th><th>Score</th><th>Suggested trade</th><th>Status</th><th></th></tr>
      <% for (const s of strategies) { const v = s.suggestion; %>
      <tr>
        <td><a href="/strategies/<%= s.id %>"><%= s.save_name %></a></td>
        <td class="score"><%= s.setup_score == null ? '—' : Math.round(s.setup_score) %></td>
        <td>
          <% if (v) { %>
            <span style="color:<%= v.side === 'long' ? 'var(--good)' : 'var(--bad)' %>;font-weight:600">
              <%= v.side === 'long' ? '▲ LONG' : '▼ SHORT' %></span>
            @ <%= v.entry ?? '—' %> → <%= v.target ?? '—' %> · stop <%= v.stop ?? '—' %>
            <span class="muted">(<%= v.label %>, <%= v.probability %>%)</span>
          <% } else { %><span class="muted">—</span><% } %>
        </td>
        <td><span class="badge <%= s.flagged ? 'flag' : 'off' %>"><%= s.flagged ? 'SETUP' : (s.active ? 'active' : 'paused') %></span></td>
        <td><form method="post" action="/strategies/<%= s.id %>/toggle" style="margin:0"><button><%= s.active ? 'Pause' : 'Activate' %></button></form></td>
      </tr>
      <% } %>
    </table>
  </div>
</main></body></html>
